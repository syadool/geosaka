    "predeploy": "npm test && npm run build",
    "deploy": "wrangler pages deploy ./dist --project-name=geosaka"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.1.1",
    "@types/leaflet": "1.9.20",
    "leaflet": "1.9.4",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.1",
    "@types/google.maps": "^3.58.1",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "25.0.1",
    "typescript": "5.6.3",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  }
}
